# ==================== MyLifeTracker 后端环境变量配置 ====================

# 服务器端口
PORT=3000

# 百度统计 Access Token（可选）
# 获取方式：https://tongji.baidu.com/api/manual/
BAIDU_STAT_TOKEN=your_baidu_stat_token_here

# 网站根目录（生产环境）
# 开发环境可以留空或设置为当前目录
WEBSITE_ROOT=/www/wwwroot/me.jiclub.site

# JS 目录（生产环境）
JS_DIRECTORY=/www/wwwroot/node

# API 鉴权密钥（重要：请修改为自己的强密钥）
# 用于保护 POST 接口（添加日志、更新任务等）
SECRET_KEY=your_strong_secret_key_here

# 行者运动 API Token（可选）
# 获取方式：https://open.imxingzhe.com/
# 用于获取骑行轨迹和运动数据
XINGZHE_TOKEN=your_xingzhe_api_token_here

# 爬取目标 URL（可选）
# 用于爬取生活动态数据
SCRAPE_TARGET_URL=https://your-target-url.com

# ==================== 说明 ====================
# 1. 复制此文件为 .env 并填写实际的配置值
# 2. .env 文件不会被提交到 Git（已在 .gitignore 中）
# 3. SECRET_KEY 必须修改，建议使用随机生成的强密钥
# 4. 开发环境中，WEBSITE_ROOT 和 JS_DIRECTORY 可以留空
# 5. 第三方 API Token 根据需要配置，不配置不影响基础功能
